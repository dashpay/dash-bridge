{
  "name": "mainnet-bridge",
  "version": "1.0.0",
  "description": "Non-custodial Dash Core to Platform bridge",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:build-artifacts": "npm run build && node scripts/check-build-artifacts.mjs",
    "test:e2e": "playwright test e2e/deterministic.spec.ts",
    "test:e2e:headed": "playwright test e2e/deterministic.spec.ts --headed",
    "test:e2e:live": "PW_E2E_LIVE=1 playwright test e2e/live.testnet.spec.ts",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@dashevo/dapi-client": "3.1.0-dev.7",
    "@dashevo/dashcore-lib": "^0.22.0",
    "@dashevo/evo-sdk": "3.1.0-dev.7",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "@scure/base": "2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "bs58check": "^4.0.0",
    "cbor": "^8.1.0",
    "dash-contract-fee-estimator": "github:PastaPastaPasta/dash-contract-fee-estimator",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^1.0.0"
  }
}
